  <!-- Scripts -->
  
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const username = localStorage.getItem("username");
      const authenDiv = document.getElementById("authenticated");
      const nonAuthenDiv = document.getElementById("non-authenticated");
      const usernameDisplay = document.getElementById("authenticated-username");

      if (username) {
        usernameDisplay.textContent = username;
        authenDiv.classList.remove("d-none");
        nonAuthenDiv.classList.add("d-none");
      } else {
        authenDiv.classList.add("d-none");
        nonAuthenDiv.classList.remove("d-none");
      }
    });

    function handleLogin(event) {
      event.preventDefault();
      const email = document.getElementById("loginAccount").value;
      localStorage.setItem("username", email);
      window.location.reload();
    }

    function logout() {
      localStorage.removeItem("username");
      window.location.reload();
    }
  </script> 
